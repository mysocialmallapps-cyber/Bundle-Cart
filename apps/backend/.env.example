NODE_ENV=development
PORT=3000

# Postgres
DATABASE_URL=postgres://postgres:postgres@localhost:5432/bundlecart

# Shopify
SHOPIFY_API_KEY=
SHOPIFY_API_SECRET=
SHOPIFY_SCOPES=read_orders,write_webhooks
APP_URL=https://your-app-public-url.example.com

# 32-byte base64 key:
# node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
ENCRYPTION_KEY_BASE64=

LOG_LEVEL=info

